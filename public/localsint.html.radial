<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Localsint Team</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  /* ============================================================
     LOCALSINT TEAM — retro desktop
     ------------------------------------------------------------
       1. Theme tokens         6. Windows (popup + app window)
       2. Reset & base         7. App-window content (lists)
       3. Intro screen         8. Start button & Start menu
       4. Desktop + ambience   9. Taskbar
       5. Desktop icons       10. Overlays (watermark, CRT…)
     ============================================================ */

  /* 1. THEME TOKENS ------------------------------------------- */
  :root {
    /* palette */
    --bg:          #000000;
    --text:        #e8e8e8;
    --faint:       #454545;
    --accent:      #43d4ff;
    --accent-rgb:  67, 212, 255;

    /* win95 chrome */
    --face:        #c0c0c0;
    --face-light:  #dfdfdf;
    --face-hi:     #ffffff;
    --face-dark:   #808080;
    --title-grad:  linear-gradient(90deg, #3d4a5c 0%, #52667c 70%, #647890 100%);

    /* motion */
    --ease-pop:    cubic-bezier(0.1, 0.9, 0.2, 1);
  }

  /* 2. RESET & BASE ------------------------------------------- */
  * { margin: 0; padding: 0; box-sizing: border-box; }

  html, body {
    height: 100%;
    overflow: hidden;
    background: var(--bg);
    color: var(--text);
    font-family: 'JetBrains Mono', ui-monospace, 'SF Mono', Menlo, monospace;
    -webkit-font-smoothing: antialiased;
    font-weight: 400;
  }

  ::selection { background: #2a2a2a; color: #fff; }

  /* ---------- INTRO ---------- */
  #intro {
    position: fixed;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: radial-gradient(ellipse at 30% 40%, #05080f, #000000 80%);
    z-index: 50;
    transition: opacity 0.7s ease, visibility 0.7s ease;
  }
  #intro.hide { opacity: 0; visibility: hidden; }

  #intro-rain {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  #title-wrap {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }
  #prompt { position: relative; z-index: 1; }
  .il {
    font-family: 'Georgia', 'Times New Roman', Times, serif;
    font-size: clamp(16px, 3vw, 32px);
    font-weight: 700;
    font-style: italic;
    letter-spacing: 0.5px;
    color: #ffffff;
    text-shadow: 0 0 20px rgba(var(--accent-rgb), 0.35);
    white-space: nowrap;
    visibility: hidden;
  }
  .il.reveal {
    visibility: visible;
    animation: writeReveal 0.8s cubic-bezier(0.15, 0.75, 0.25, 1) forwards;
  }
  @keyframes writeReveal {
    from { clip-path: inset(0 100% 0 0); }
    to   { clip-path: inset(0 0 0 0); }
  }

  #prompt {
    margin-top: 30px;
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--faint);
    opacity: 0;
    transition: opacity 0.8s ease;
  }
  #prompt.show { opacity: 1; animation: breathe 2.4s ease-in-out infinite; }
  @keyframes breathe { 0%,100%{opacity:.7} 50%{opacity:.25} }

  /* ---------- DESKTOP ---------- */
  #desktop {
    position: fixed;
    inset: 0;
    background: radial-gradient(ellipse at 30% 40%, #05080f, #000000 80%);
    opacity: 0;
    transition: opacity 0.8s ease;
    image-rendering: pixelated;
  }
  #desktop.show { opacity: 1; }

  /* ---------- STARS ---------- */
  #stars {
    position: fixed;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }



  /* ---------- DESKTOP ICON ---------- */
  .icon {
    position: absolute;
    top: 18px; left: 18px;
    width: 76px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    cursor: pointer;
    padding: 6px;
    border: 2px solid transparent;
    border-radius: 4px;
    user-select: none;
    transition: transform 0.15s cubic-bezier(0.1, 0.9, 0.2, 1),
                background 0.15s ease, border-color 0.15s ease;
  }
  .icon:hover, .icon.active {
    background: rgba(var(--accent-rgb), 0.12);
    border-color: rgba(var(--accent-rgb), 0.45);
  }
  .icon:hover {
    transform: scale(1.08);
  }
  .icon .pic {
    width: 48px; height: 48px;
    object-fit: cover;
    image-rendering: pixelated;
    background: radial-gradient(circle at 35% 28%, #6d7480, #383c44);
    border-radius: 7px;
    box-shadow:
      inset 0 0 0 1px rgba(255,255,255,0.14),
      inset 0 1px 1px rgba(255,255,255,0.22),
      0 2px 5px rgba(0,0,0,0.45);
  }
  .icon .name {
    font-family: Tahoma, 'MS Sans Serif', Geneva, sans-serif;
    font-size: 11px;
    font-weight: 700;
    line-height: 1.3;
    color: #d8f2ff;
    text-shadow:
      1px 1px 1px rgba(0,0,0,0.95),
      0 0 6px rgba(var(--accent-rgb), 0.4);
  }

  /* ---------- POPUP ---------- */
  .popup {
    position: fixed;
    top: 90px; left: 200px;
    width: 250px;
    background: #c0c0c0;
    box-shadow:
      inset 0 0 0 1px #000,
      inset 0 0 0 2px #dfdfdf,
      inset -1px -1px 0 #808080,
      6px 6px 0 rgba(0,0,0,0.55),
      0 10px 34px rgba(0,0,0,0.5);
    padding: 2px;
    z-index: 30;
    opacity: 0;
    visibility: hidden;
    transform: scale(0.96);
    transform-origin: top left;
    transition: opacity 0.18s ease, transform 0.18s cubic-bezier(0.1,0.9,0.2,1), visibility 0.18s;
    font-family: 'MS Sans Serif', Tahoma, sans-serif;
  }
  .popup.open {
    opacity: 1;
    visibility: visible;
    transform: scale(1);
  }
  .popup-bar {
    background: var(--title-grad);
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    padding: 3px 3px 3px 4px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: move;
    user-select: none;
    letter-spacing: 0.2px;
    text-shadow: 1px 1px 0 rgba(0,0,0,0.35);
  }
  .popup-title {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .popup-title::before {
    content: "";
    width: 14px; height: 14px;
    border-radius: 2px;
    background: linear-gradient(135deg, #f4f4f4, #b8b8b8);
    box-shadow: inset 0 0 0 1px #606060, inset 1px 1px 0 #ffffff;
    flex-shrink: 0;
  }
  .popup-x {
    width: 16px; height: 14px;
    background: #c0c0c0;
    color: #000;
    font-size: 11px;
    font-weight: 700;
    font-family: 'MS Sans Serif', Tahoma, sans-serif;
    line-height: 12px;
    display: grid;
    place-items: center;
    cursor: pointer;
    box-shadow:
      inset 0 1px 0 #ffffff,
      inset 1px 0 0 #ffffff,
      inset -1px 0 0 #808080,
      inset 0 -1px 0 #808080;
    user-select: none;
  }
  .popup-x:active {
    box-shadow:
      inset 0 1px 0 #808080,
      inset 1px 0 0 #808080,
      inset -1px 0 0 #dfdfdf,
      inset 0 -1px 0 #dfdfdf;
  }
  .popup-body {
    padding: 16px 14px 14px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    background:
      repeating-linear-gradient(0deg, rgba(0,0,0,0.015) 0 1px, transparent 1px 3px),
      #c0c0c0;
  }
  .popup-avatar {
    width: 72px; height: 72px;
    padding: 3px;
    background: #808080;
    box-shadow: inset 0 0 0 1px #000, inset 1px 1px 0 #ffffff;
    border-radius: 6px;
  }
  .popup-avatar img {
    display: block;
    width: 100%; height: 100%;
    object-fit: cover;
    border-radius: 4px;
  }
  .popup-name {
    font-size: 16px;
    font-weight: 700;
    color: #000;
    margin-top: 4px;
  }
  .popup-role {
    font-size: 11px;
    font-weight: 400;
    color: #000;
    font-family: 'MS Sans Serif', Tahoma, sans-serif;
  }
  .popup-views {
    font-size: 10px;
    color: #444;
    font-family: 'MS Sans Serif', Tahoma, sans-serif;
    align-self: flex-end;
    margin-bottom: 2px;
  }
  .popup-sep {
    width: 100%;
    height: 2px;
    margin: 4px 0;
    background: #808080;
    box-shadow: 0 1px 0 #ffffff;
  }
  .popup-link {
    font-size: 11px;
    color: #000080;
    text-decoration: underline;
    cursor: pointer;
    font-family: 'MS Sans Serif', Tahoma, sans-serif;
  }
  .popup-link:hover { color: #ff0000; }
  .popup-ok {
    margin-top: 6px;
    padding: 4px 28px;
    font-family: 'MS Sans Serif', Tahoma, sans-serif;
    font-size: 11px;
    font-weight: 600;
    color: #000;
    background: #c0c0c0;
    border: none;
    box-shadow:
      inset 0 1px 0 #ffffff,
      inset 1px 0 0 #ffffff,
      inset -1px 0 0 #808080,
      inset 0 -1px 0 #808080;
    cursor: pointer;
    user-select: none;
  }
  .popup-ok:active {
    box-shadow:
      inset 0 1px 0 #808080,
      inset 1px 0 0 #808080,
      inset -1px 0 0 #dfdfdf,
      inset 0 -1px 0 #dfdfdf;
  }

  .popup-socials {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .popup-socials .ps {
    font-size: 11px;
    font-family: 'MS Sans Serif', Tahoma, sans-serif;
    color: #000080;
    text-decoration: underline;
    cursor: pointer;
    padding: 2px 4px;
  }
  .popup-socials .ps:hover { color: #ff0000; }

  /* ---------- APP WINDOW CONTENT ---------- */
  .aw-intro {
    font-family: 'MS Sans Serif', Tahoma, sans-serif;
    font-size: 11px;
    color: #000;
    line-height: 1.5;
    margin-bottom: 4px;
  }
  .aw-list {
    display: flex;
    flex-direction: column;
    gap: 4px;
    background: #ffffff;
    box-shadow:
      inset 1px 1px 0 #808080,
      inset -1px -1px 0 #ffffff,
      inset 2px 2px 0 #000;
    padding: 6px;
    max-height: 180px;
    overflow-y: auto;
  }
  .aw-item {
    display: grid;
    grid-template-columns: 14px 1fr auto;
    align-items: baseline;
    column-gap: 8px;
    row-gap: 2px;
    font-family: 'MS Sans Serif', Tahoma, sans-serif;
    font-size: 11px;
    color: #000;
    padding: 4px 5px;
    cursor: pointer;
    text-decoration: none;
    border: 1px solid transparent;
  }
  .aw-item::before {
    content: "";
    width: 12px; height: 10px;
    align-self: center;
    flex-shrink: 0;
    background: #d0b060;
    box-shadow: inset 0 0 0 1px #705000;
  }
  .aw-item:hover { background: #000080; color: #fff; }
  .aw-item:hover .aw-meta,
  .aw-item:hover .aw-desc { color: #c8d0f0; }
  .aw-item.link::before { background: #6090d0; box-shadow: inset 0 0 0 1px #204070; }
  .aw-label { font-weight: 600; }
  .aw-item.link .aw-label { text-decoration: underline; }
  .aw-meta {
    font-size: 10px;
    color: #555;
    white-space: nowrap;
  }
  .aw-desc {
    grid-column: 2 / 4;
    font-size: 10px;
    color: #444;
    line-height: 1.45;
  }
  .aw-empty {
    font-family: 'MS Sans Serif', Tahoma, sans-serif;
    font-size: 11px;
    color: #444;
    text-align: center;
    padding: 10px;
  }

  /* ---------- START BUTTON ---------- */
  .start-btn {
    display: flex;
    align-items: center;
    gap: 5px;
    height: 26px;
    padding: 0 9px 0 5px;
    background: linear-gradient(180deg, #d8d8d8, #b6b6b6);
    box-shadow:
      inset 0 1px 0 #f4f4f4,
      inset 1px 0 0 #f4f4f4,
      inset -1px 0 0 #808080,
      inset 0 -1px 0 #808080;
    border: none;
    border-radius: 3px;
    font-family: 'MS Sans Serif', Tahoma, sans-serif;
    font-size: 12px;
    font-weight: 700;
    color: #000;
    cursor: pointer;
    flex-shrink: 0;
    user-select: none;
  }
  .start-btn:hover { filter: brightness(1.05); }
  .start-btn.open,
  .start-btn:active {
    box-shadow:
      inset 0 1px 0 #808080,
      inset 1px 0 0 #808080,
      inset -1px 0 0 #dfdfdf,
      inset 0 -1px 0 #dfdfdf;
  }
  .start-btn .sb-logo {
    width: 16px; height: 16px;
    flex-shrink: 0;
    display: block;
  }
  .start-btn .sb-logo * { stroke: var(--accent); }
  .tb-divider {
    width: 2px;
    height: 24px;
    margin: 0 3px;
    background: #808080;
    box-shadow: 1px 0 0 #f0f0f0;
    flex-shrink: 0;
  }

  /* ---------- START MENU ---------- */
  .startmenu {
    position: absolute;
    left: 2px;
    bottom: 37px;
    display: flex;
    min-width: 210px;
    background: #c0c0c0;
    box-shadow:
      inset 0 1px 0 #ffffff,
      inset 1px 0 0 #ffffff,
      inset -1px -1px 0 #808080,
      inset -2px -2px 0 #404040,
      5px 5px 0 rgba(0,0,0,0.5);
    padding: 2px;
    z-index: 20;
    opacity: 0;
    visibility: hidden;
    transform: translateY(4px);
    transition: opacity .14s ease, transform .14s ease, visibility .14s;
  }
  .startmenu.open { opacity: 1; visibility: visible; transform: translateY(0); }
  .sm-side {
    width: 26px;
    flex-shrink: 0;
    background: linear-gradient(180deg, #52667c, #2c3644);
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding: 8px 0;
  }
  .sm-side span {
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    font-family: 'Georgia', serif;
    font-style: italic;
    font-size: 15px;
    font-weight: 700;
    color: #e8ecff;
    letter-spacing: 1px;
    text-shadow: 1px 1px 1px rgba(0,0,0,0.5);
    white-space: nowrap;
  }
  .sm-items {
    flex: 1;
    padding: 3px;
    display: flex;
    flex-direction: column;
  }
  .sm-item {
    display: flex;
    align-items: center;
    gap: 9px;
    padding: 6px 14px 6px 8px;
    font-family: 'MS Sans Serif', Tahoma, sans-serif;
    font-size: 12px;
    color: #000;
    cursor: pointer;
    user-select: none;
  }
  .sm-item .sm-ico {
    width: 20px; height: 20px;
    flex-shrink: 0;
    display: grid;
    place-items: center;
  }
  .sm-item:hover { background: #000080; color: #fff; }
  .sm-sep {
    height: 2px;
    margin: 3px 2px;
    background: #808080;
    box-shadow: 0 1px 0 #ffffff;
  }

  /* ---------- TASKBAR (pixelated / low-fi) ---------- */
  .taskbar, .taskbar * {
    -webkit-font-smoothing: none;
    text-rendering: optimizeSpeed;
    image-rendering: pixelated;
  }
  .taskbar {
    position: absolute;
    left: 0; right: 0; bottom: 0;
    height: 36px;
    background: linear-gradient(180deg, #e0e0e0 0%, #c0c0c0 20%, #b0b0b0 100%);
    box-shadow:
      inset 0 1px 0 #f4f4f4,
      inset 0 2px 0 #e8e8e8;
    border-top: 1px solid #888;
    display: flex;
    align-items: center;
    padding: 0 4px;
    gap: 3px;
    z-index: 10;
  }
  .taskbar .tb-btn {
    width: 30px; height: 28px;
    padding: 2px;
    background: linear-gradient(180deg, #d4d4d4, #b4b4b4);
    box-shadow:
      inset 0 1px 0 #f0f0f0,
      inset 1px 0 0 #f0f0f0,
      inset -1px 0 0 #888,
      inset 0 -1px 0 #888;
    border-radius: 3px;
    cursor: pointer;
    flex-shrink: 0;
    transition: filter 0.1s;
  }
  .taskbar .tb-btn:hover {
    filter: brightness(1.06);
  }
  .taskbar .tb-btn:active {
    box-shadow:
      inset 0 1px 0 #888,
      inset 1px 0 0 #888,
      inset -1px 0 0 #ddd,
      inset 0 -1px 0 #ddd;
  }
  .taskbar .tb-btn img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 2px;
  }
  .taskbar .spacer {
    flex: 1;
  }
  .taskbar .clock {
    height: 22px;
    padding: 0 6px;
    background: #c0c0c0;
    box-shadow:
      inset 0 0 0 1px #888,
      inset 1px 1px 0 #ddd;
    display: flex;
    align-items: center;
    font-family: 'MS Sans Serif', Tahoma, sans-serif;
    font-size: 11px;
    font-weight: 600;
    color: #111;
    flex-shrink: 0;
    user-select: none;
    letter-spacing: 0.3px;
  }

  /* open-window buttons */
  .task-buttons {
    flex: 1;
    min-width: 0;
    height: 28px;
    display: flex;
    align-items: center;
    gap: 3px;
    overflow: hidden;
  }
  .task-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    height: 26px;
    max-width: 168px;
    padding: 0 9px;
    background: linear-gradient(180deg, #d8d8d8, #b8b8b8);
    box-shadow:
      inset 0 1px 0 #f0f0f0, inset 1px 0 0 #f0f0f0,
      inset -1px 0 0 #888, inset 0 -1px 0 #888;
    border: none;
    border-radius: 3px;
    font-family: 'MS Sans Serif', Tahoma, sans-serif;
    font-size: 11px;
    color: #111;
    cursor: pointer;
    flex: 0 1 auto;
    min-width: 0;
    transition: filter .1s;
  }
  .task-btn:hover { filter: brightness(1.05); }
  .task-btn .tbi { width: 14px; height: 14px; flex-shrink: 0; display: grid; place-items: center; }
  .task-btn .tbl { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .task-btn.active {
    background: linear-gradient(180deg, #aeaeae, #c6c6c6);
    box-shadow:
      inset 0 1px 0 #888, inset 1px 0 0 #888,
      inset -1px 0 0 #eee, inset 0 -1px 0 #eee;
    font-weight: 700;
  }

  /* volume control (discord-style) */
  .vol { position: relative; flex-shrink: 0; }
  .vol-btn {
    width: 28px; height: 26px;
    display: grid; place-items: center;
    background: linear-gradient(180deg, #d4d4d4, #b4b4b4);
    box-shadow:
      inset 0 1px 0 #f0f0f0, inset 1px 0 0 #f0f0f0,
      inset -1px 0 0 #888, inset 0 -1px 0 #888;
    border: none;
    border-radius: 3px;
    color: #1a1a1a;
    cursor: pointer;
    transition: filter .1s;
  }
  .vol-btn:hover { filter: brightness(1.06); }
  .vol-btn .vx { opacity: 0; }
  .vol.low  .vol-btn .vw { opacity: 0; }
  .vol.muted .vol-btn { color: #c0392b; }
  .vol.muted .vol-btn .vw { opacity: 0; }
  .vol.muted .vol-btn .vx { opacity: 1; }

  .vol-panel {
    position: absolute;
    bottom: 34px;
    right: 0;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 10px;
    background: var(--face);
    box-shadow:
      inset 0 1px 0 var(--face-hi), inset 1px 0 0 var(--face-hi),
      inset -1px -1px 0 var(--face-dark), inset -2px -2px 0 #404040,
      4px 4px 0 rgba(0,0,0,0.5);
    opacity: 0;
    visibility: hidden;
    transform: translateY(6px);
    transition: opacity .14s ease, transform .14s var(--ease-pop), visibility .14s;
    z-index: 25;
  }
  .vol-panel.open,
  .vol:hover .vol-panel,
  .vol:focus-within .vol-panel { opacity: 1; visibility: visible; transform: translateY(0); }
  /* invisible bridge so the cursor can cross the gap without closing the panel */
  .vol-panel::after {
    content: "";
    position: absolute;
    left: 0; right: 0; bottom: -12px;
    height: 12px;
  }
  .vol-val {
    font-family: 'MS Sans Serif', Tahoma, sans-serif;
    font-size: 11px;
    color: #000;
    min-width: 24px;
    text-align: right;
    padding: 1px 4px;
    background: #fff;
    box-shadow: inset 1px 1px 0 var(--face-dark), inset -1px -1px 0 var(--face-light);
  }
  /* win95 trackbar */
  .vol-slider {
    -webkit-appearance: none;
    appearance: none;
    width: 116px;
    height: 18px;
    background: transparent;
    cursor: pointer;
    outline: none;
  }
  .vol-slider::-webkit-slider-runnable-track {
    height: 6px;
    background: linear-gradient(90deg,
      var(--accent) 0 var(--fill, 70%), #9a9a9a var(--fill, 70%) 100%);
    box-shadow: inset 1px 1px 0 var(--face-dark), inset -1px -1px 0 var(--face-hi);
  }
  .vol-slider::-webkit-slider-thumb {
    -webkit-appearance: none; appearance: none;
    width: 11px; height: 18px;
    margin-top: -6px;
    border-radius: 0;
    background: linear-gradient(180deg, #dcdcdc, #a8a8a8);
    box-shadow:
      inset 1px 1px 0 var(--face-hi), inset -1px -1px 0 var(--face-dark),
      0 1px 0 #606060;
    cursor: pointer;
  }
  .vol-slider::-moz-range-track {
    height: 6px;
    background: #9a9a9a;
    box-shadow: inset 1px 1px 0 var(--face-dark), inset -1px -1px 0 var(--face-hi);
  }
  .vol-slider::-moz-range-progress {
    height: 6px;
    background: var(--accent);
  }
  .vol-slider::-moz-range-thumb {
    width: 11px; height: 18px;
    border: none;
    border-radius: 0;
    background: linear-gradient(180deg, #dcdcdc, #a8a8a8);
    box-shadow: inset 1px 1px 0 var(--face-hi), inset -1px -1px 0 var(--face-dark);
    cursor: pointer;
  }

  /* ---------- WATERMARK ---------- */
  #watermark {
    position: fixed;
    bottom: 50px;
    right: -60px;
    width: 800px;
    height: auto;
    z-index: 40;
    pointer-events: none;
    image-rendering: pixelated;
    user-select: none;
    opacity: 0.14;
    filter: blur(3px) saturate(0.7) contrast(0.9);
    animation: watermarkGlitch 4.2s ease-in-out infinite;
  }
  @keyframes watermarkGlitch {
    0%, 90%, 100% { filter: blur(3px) saturate(0.7) contrast(0.9); transform: translate(0) scale(1); }
    91% { filter: blur(5px) saturate(1.4) brightness(1.3) hue-rotate(12deg); transform: translate(4px, -2px) scale(1.01); }
    93% { filter: blur(1.5px) saturate(0.5) contrast(1.2) hue-rotate(-8deg); transform: translate(-6px, 2px) scale(0.99); }
    95% { filter: blur(4px) saturate(1.5) brightness(0.8); transform: translate(8px, -3px) scale(1.02); }
    97% { filter: blur(2px) saturate(0.8) contrast(1.1); transform: translate(-3px, 1px) scale(1); }
  }

  /* ---------- CURSOR TRAIL ---------- */
  #trail {
    position: fixed;
    inset: 0;
    z-index: 3;
    pointer-events: none;
    image-rendering: pixelated;
  }

  /* ---------- DESKTOP HEADER ---------- */

  /* ---------- SCANLINES ---------- */
  #scanlines {
    position: fixed;
    inset: 0;
    z-index: 4;
    pointer-events: none;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0,0,0,0.08) 2px,
      rgba(0,0,0,0.08) 4px
    );
  }

  /* ---------- VIGNETTE ---------- */
  #vignette {
    position: fixed;
    inset: 0;
    z-index: 4;
    pointer-events: none;
    background: radial-gradient(ellipse at center, transparent 60%, rgba(0,0,0,0.6) 100%);
  }

  /* ---------- FLOATING DUST ---------- */
  #dust {
    position: fixed;
    inset: 0;
    z-index: 3;
    pointer-events: none;
  }

  /* ---------- CRT FLICKER ---------- */
  #flicker {
    position: fixed;
    inset: 0;
    z-index: 4;
    pointer-events: none;
    opacity: 0;
    animation: crtFlicker 0.15s infinite;
  }
  @keyframes crtFlicker {
    0% { opacity: 0; }
    50% { opacity: 0.008; }
    100% { opacity: 0; }
  }
</style>
</head>
<body>

  <!-- INTRO -->
  <section id="intro">
    <canvas id="intro-rain"></canvas>
    <div id="title-wrap">
      <div class="il">this is the website team of localsint.org</div>
      <div class="il">analizing data</div>
      <div class="il">confirmed</div>
    </div>
    <div id="prompt">press anywhere to continue</div>
  </section>

  <!-- watermark -->
  <img id="watermark" src="image.png" alt="" draggable="false">

  <!-- DESKTOP -->
  <section id="desktop">

    <!-- stars canvas -->
    <canvas id="stars"></canvas>

    <!-- top-left icon -->
    <div class="icon" id="sero-icon" title="Sero" style="top:22px;left:22px">
      <img class="pic" src="sero/sero.png" alt="Sero" onerror="this.style.visibility='hidden'">
      <div class="name">Sero</div>
    </div>

    <!-- yale — Dev / Co Founder — 2 places below sero -->
    <div class="icon" id="yale-icon" title="Yale" style="top:218px;left:22px">
      <img class="pic" src="yale/yale.png" alt="Yale" onerror="this.onerror=null;this.src='yale/avatar.svg'">
      <div class="name">Yale</div>
    </div>

    <!-- tophet — below yale -->
    <div class="icon" id="tophet-icon" title="Tophet" style="top:316px;left:22px">
      <img class="pic" src="tophet/tophet.png" alt="Tophet">
      <div class="name">Tophet</div>
    </div>

    <!-- Alex Moar — Localsint Owner — directly below sero -->
    <div class="icon" id="alex-icon" title="Alex Moar" style="top:120px;left:22px">
      <img class="pic" src="alex%20moar/alex%20moar.png" alt="Alex Moar" onerror="this.onerror=null;this.src='yale/avatar.svg'">
      <div class="name">Alex Moar</div>
    </div>

    <!-- extra desktop icons — stacked in a column -->
    <div class="icon" title="localsint" data-app="localsint" style="top:22px;left:118px">
      <div class="pic" style="display:flex;align-items:center;justify-content:center;">
        <svg viewBox="0 0 48 48" width="32" height="32">
          <circle cx="24" cy="24" r="18" fill="none" stroke="#a0c0f0" stroke-width="1.5"/>
          <ellipse cx="24" cy="24" rx="18" ry="8" fill="none" stroke="#a0c0f0" stroke-width="1.2"/>
          <line x1="6" y1="24" x2="42" y2="24" stroke="#a0c0f0" stroke-width="1.2"/>
          <line x1="24" y1="6" x2="24" y2="42" stroke="#a0c0f0" stroke-width="1.2"/>
          <path d="M12 12 Q24 20 36 12" fill="none" stroke="#a0c0f0" stroke-width="1"/>
          <path d="M12 36 Q24 28 36 36" fill="none" stroke="#a0c0f0" stroke-width="1"/>
        </svg>
      </div>
      <div class="name">localsint</div>
    </div>
    <div class="icon" title="projects" data-app="projects" style="top:120px;left:118px">
      <div class="pic" style="display:flex;align-items:center;justify-content:center;">
        <svg viewBox="0 0 48 48" width="36" height="36">
          <path d="M8 12 L8 40 L40 40 L40 16 L24 16 L20 12 Z" fill="#a0a000" stroke="#606000" stroke-width="1.5"/>
          <path d="M8 12 L20 12 L24 16 L40 16" fill="none" stroke="#606000" stroke-width="1.5"/>
          <line x1="16" y1="26" x2="32" y2="26" stroke="#606000" stroke-width="1.5"/>
          <line x1="16" y1="32" x2="28" y2="32" stroke="#606000" stroke-width="1.5"/>
        </svg>
      </div>
      <div class="name">projects</div>
    </div>
    <div class="icon" title="archive" data-app="archive" style="top:218px;left:118px">
      <div class="pic" style="display:flex;align-items:center;justify-content:center;">
        <svg viewBox="0 0 48 48" width="36" height="36">
          <rect x="8" y="12" width="32" height="26" rx="2" fill="#a08050" stroke="#604020" stroke-width="1.5"/>
          <rect x="12" y="16" width="24" height="4" rx="1" fill="#806040" stroke="#604020" stroke-width="1"/>
          <line x1="16" y1="24" x2="32" y2="24" stroke="#604020" stroke-width="1.5"/>
          <line x1="16" y1="30" x2="28" y2="30" stroke="#604020" stroke-width="1.5"/>
        </svg>
      </div>
      <div class="name">archive</div>
    </div>



    <!-- profile popup -->
    <div class="popup" id="popup">
      <div class="popup-bar">
        <span class="popup-title" id="popup-title">sero</span>
        <span class="popup-x" id="popup-x">×</span>
      </div>
      <div class="popup-body">
        <div class="popup-views" id="popup-views"><svg viewBox="0 0 24 24" width="12" height="12" style="vertical-align:-2px;margin-right:3px;"><path fill="#666" d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/></svg> 0</div>
        <div class="popup-avatar">
          <img id="popup-pic" src="sero/sero.png" alt="">
        </div>
        <div class="popup-name" id="popup-name"></div>
        <div class="popup-role" id="popup-role"></div>
        <div class="popup-sep"></div>
        <a class="popup-link" id="popup-link" href="https://localsint.org" target="_blank" rel="noopener">localsint.org ↗</a>
        <div class="popup-socials">
          <a class="ps" id="ps-discord" href="https://discord.com/users/1505870670633111624" target="_blank" rel="noopener" title="Discord">
            <svg viewBox="0 0 24 24" width="18" height="18"><path fill="#5865f2" d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>
          </a>
          <a class="ps" id="ps-telegram" href="https://t.me/xysghasdghjdfxcvzyx" target="_blank" rel="noopener" title="Telegram">
            <svg viewBox="0 0 24 24" width="18" height="18"><path fill="#229ed9" d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
          </a>
          <a class="ps" id="ps-doxbin" href="#" target="_blank" rel="noopener" title="Doxbin" style="display:none;">
            <svg viewBox="0 0 24 24" width="18" height="18"><path fill="#cc3333" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zM6 20V4h7v5h5v11H6z"/><path fill="#cc3333" d="M8 12h8v2H8zm0 4h6v2H8zm0-8h4v2H8z"/></svg>
          </a>
        </div>
        <button class="popup-ok" id="popup-ok">OK</button>
      </div>
    </div>

    <!-- generic app window (localsint / projects / archive) -->
    <div class="popup" id="appwin" style="width:300px;">
      <div class="popup-bar" id="appwin-bar">
        <span class="popup-title" id="appwin-title">window</span>
        <span class="popup-x" id="appwin-x">×</span>
      </div>
      <div class="popup-body" id="appwin-body" style="align-items:stretch;text-align:left;"></div>
    </div>

    <!-- start menu -->
    <div class="startmenu" id="startmenu">
      <div class="sm-side"><span>Localsint&nbsp;Team</span></div>
      <div class="sm-items">
        <div class="sm-item" data-start="sero">
          <span class="sm-ico"><img src="sero/sero.png" alt="" style="width:18px;height:18px;object-fit:cover;border-radius:3px;" onerror="this.style.visibility='hidden'"></span>
          sero
        </div>
        <div class="sm-item" data-start="tophet">
          <span class="sm-ico"><img src="tophet/tophet.png" alt="" style="width:18px;height:18px;object-fit:cover;border-radius:3px;"></span>
          tophet
        </div>
        <div class="sm-item" data-start="localsint">
          <span class="sm-ico"><svg viewBox="0 0 48 48" width="18" height="18"><circle cx="24" cy="24" r="18" fill="none" stroke="#3060a0" stroke-width="2.2"/><ellipse cx="24" cy="24" rx="18" ry="8" fill="none" stroke="#3060a0" stroke-width="1.8"/><line x1="6" y1="24" x2="42" y2="24" stroke="#3060a0" stroke-width="1.8"/><line x1="24" y1="6" x2="24" y2="42" stroke="#3060a0" stroke-width="1.8"/></svg></span>
          localsint
        </div>
        <div class="sm-item" data-start="projects">
          <span class="sm-ico"><svg viewBox="0 0 48 48" width="18" height="18"><path d="M8 12 L8 40 L40 40 L40 16 L24 16 L20 12 Z" fill="#d0b040" stroke="#705000" stroke-width="2"/></svg></span>
          projects
        </div>
        <div class="sm-item" data-start="archive">
          <span class="sm-ico"><svg viewBox="0 0 48 48" width="18" height="18"><rect x="8" y="12" width="32" height="26" rx="2" fill="#a08050" stroke="#604020" stroke-width="2"/><rect x="12" y="16" width="24" height="5" rx="1" fill="#806040" stroke="#604020" stroke-width="1.5"/></svg></span>
          archive
        </div>
        <div class="sm-sep"></div>
        <a class="sm-item" href="https://localsint.org" target="_blank" rel="noopener" style="text-decoration:none;">
          <span class="sm-ico">🌐</span>
          localsint.org
        </a>
      </div>
    </div>

    <div class="taskbar">
      <button class="start-btn" id="start-btn">
        <svg class="sb-logo" viewBox="0 0 48 48"><circle cx="24" cy="24" r="20" fill="none" stroke="#1068c8" stroke-width="3"/><ellipse cx="24" cy="24" rx="20" ry="9" fill="none" stroke="#1068c8" stroke-width="2.5"/><line x1="4" y1="24" x2="44" y2="24" stroke="#1068c8" stroke-width="2.5"/><line x1="24" y1="4" x2="24" y2="44" stroke="#1068c8" stroke-width="2.5"/></svg>
        Start
      </button>
      <div class="tb-divider"></div>
      <div class="tb-btn" data-name="Sero" data-role="Localsint Owner" data-pic="sero/sero.png"
           data-discord="https://discord.com/users/1505870670633111624"
           data-telegram="https://t.me/xysghasdghjdfxcvzyx"
           data-link="https://localsint.org" data-audio="sero/sero.mp3">
        <img src="sero/sero.png" alt="">
      </div>
      <div class="tb-btn" data-name="Yale" data-role="Dev / Co Founder" data-pic="yale/yale.png"
           data-discord="https://discord.com/users/1407152287209750558"
           data-telegram="https://t.me/amidated"
           data-link="https://localsint.org" data-audio="yale/yale.mp3">
        <img src="yale/yale.png" alt="" onerror="this.onerror=null;this.src='yale/avatar.svg'">
      </div>
      <div class="tb-btn" data-name="Tophet" data-role="Support" data-pic="tophet/tophet.png"
           data-telegram="https://t.me/t_phet"
           data-doxbin="https://doxbin.com/users?query=tophet" data-audio="tophet/tophet.mp3">
        <img src="tophet/tophet.png" alt="">
      </div>
      <div class="tb-btn" data-name="Alex Moar" data-role="Localsint Owner" data-pic="alex%20moar/alex%20moar.png"
           data-link="https://localsint.org">
        <img src="alex%20moar/alex%20moar.png" alt="" onerror="this.onerror=null;this.src='yale/avatar.svg'">
      </div>
      <div class="tb-divider"></div>

      <!-- open-window buttons appear here -->
      <div class="task-buttons" id="task-buttons"></div>

      <!-- volume control -->
      <div class="vol" id="vol">
        <button class="vol-btn" id="vol-btn" title="Volume" aria-label="Volume">
          <svg id="vol-icon" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
            <path class="vs" d="M4 9v6h4l5 4V5L8 9H4z" fill="currentColor"/>
            <g class="vw">
              <path d="M15.5 8.5a4 4 0 0 1 0 7" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
              <path d="M18 6a7.5 7.5 0 0 1 0 12" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
            </g>
            <g class="vx" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
              <line x1="16" y1="9" x2="21" y2="15"/>
              <line x1="21" y1="9" x2="16" y2="15"/>
            </g>
          </svg>
        </button>
        <div class="vol-panel" id="vol-panel">
          <input class="vol-slider" id="vol-slider" type="range" min="0" max="100" value="70" aria-label="Volume level">
          <span class="vol-val" id="vol-val">70</span>
        </div>
      </div>

      <div class="clock" id="clock"></div>
    </div>

    <!-- trail canvas -->
    <canvas id="trail"></canvas>



    <!-- dust canvas -->
    <canvas id="dust"></canvas>

    <!-- scanlines -->
    <div id="scanlines"></div>

    <!-- vignette -->
    <div id="vignette"></div>

    <!-- crt flicker -->
    <div id="flicker"></div>

    <!-- audio -->
    <audio id="sero-audio" src="sero/sero.mp3" preload="auto"></audio>
    <audio id="tophet-audio" src="tophet/tophet.mp3" preload="auto"></audio>

  </section>

<script>
  /* ---- intro: stylus writing ---- */
  const lines = document.querySelectorAll(".il");
  const prompt = document.getElementById("prompt");
  let ready = false;

  function revealLines(i) {
    if (i >= lines.length) {
      setTimeout(() => {
        prompt.classList.add("show");
        ready = true;
      }, 600);
      return;
    }
    lines[i].classList.add("reveal");
    setTimeout(() => revealLines(i + 1), 1000);
  }

  setTimeout(() => revealLines(0), 400);

  /* ---- enter desktop ---- */
  const intro = document.getElementById("intro");
  const desktop = document.getElementById("desktop");
  let entered = false;
  function enter() {
    if (!ready || entered) return;
    entered = true;
    document.getElementById("watermark").src = "image.png";
    intro.classList.add("hide");
    setTimeout(() => { intro.style.display = "none"; desktop.classList.add("show"); }, 450);
  }
  window.addEventListener("click", enter);
  window.addEventListener("keydown", enter);
  window.addEventListener("touchstart", enter, { passive: true });

  /* ---- intro ambience: starfield + cursor shadow (matches the desktop) ---- */
  const irCanvas = document.getElementById("intro-rain");
  const irCtx = irCanvas.getContext("2d");
  let irDrops = [];
  let irActive = false, irLastX = 0, irLastY = 0;

  function irResize() { irCanvas.width = window.innerWidth; irCanvas.height = window.innerHeight; }
  irResize();
  window.addEventListener("resize", irResize);

  // twinkling starfield behind the intro rain (matches the desktop)
  let irStars = [];
  function irSeedStars() {
    irStars = [];
    for (let i = 0; i < 190; i++) {
      irStars.push({
        x: Math.random() * irCanvas.width,
        y: Math.random() * irCanvas.height,
        r: 0.2 + Math.random() * 1.8,
        a: 0.15 + Math.random() * 0.6,
        ph: Math.random() * Math.PI * 2,
        sp: 0.01 + Math.random() * 0.05,
      });
    }
  }
  irSeedStars();
  window.addEventListener("resize", irSeedStars);

  // cursor droplets while the intro is up
  document.addEventListener("mousemove", (e) => {
    if (entered) return;
    if (!irActive) { irActive = true; irLastX = e.clientX; irLastY = e.clientY; return; }
    const dx = e.clientX - irLastX, dy = e.clientY - irLastY;
    if (dx * dx + dy * dy > 4) {
      // cursor makes a soft shadow that lingers into a trail (no falling)
      irDrops.push({
        x: e.clientX, y: e.clientY,
        r: 4 + Math.random() * 3.5,
        cursor: true, life: 1,
      });
      irLastX = e.clientX; irLastY = e.clientY;
    }
  });

  function irDraw() {
    if (entered) { irCtx.clearRect(0, 0, irCanvas.width, irCanvas.height); return; }
    irCtx.clearRect(0, 0, irCanvas.width, irCanvas.height);
    // twinkling starfield (same as the desktop)
    const st = Date.now() * 0.001;
    for (const s of irStars) {
      const tw = s.a * (0.6 + 0.4 * Math.sin(st * s.sp * 10 + s.ph));
      irCtx.beginPath();
      irCtx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
      irCtx.fillStyle = `rgba(180,200,240,${tw})`;
      irCtx.fill();
    }
    // cursor shadow droplets (same soft fade as the desktop)
    for (let i = irDrops.length - 1; i >= 0; i--) {
      const d = irDrops[i];
      d.life -= 0.03;
      d.r += 0.4;
      if (d.life <= 0) { irDrops.splice(i, 1); continue; }
      const grad = irCtx.createRadialGradient(d.x, d.y, 0, d.x, d.y, d.r);
      grad.addColorStop(0, `rgba(135,170,215,${d.life * 0.34})`);
      grad.addColorStop(1, `rgba(60,80,110,0)`);
      irCtx.beginPath();
      irCtx.arc(d.x, d.y, d.r, 0, Math.PI * 2);
      irCtx.fillStyle = grad;
      irCtx.fill();
    }
    if (irDrops.length > 300) irDrops.splice(0, irDrops.length - 300);
    requestAnimationFrame(irDraw);
  }
  irDraw();

  /* ---- taskbar popup ---- */
  const popup = document.getElementById("popup");
  const popupBar = document.querySelector(".popup-bar");
  const popupPic = document.getElementById("popup-pic");
  const popupName = document.getElementById("popup-name");
  const popupRole = document.getElementById("popup-role");
  const popupTitle = document.getElementById("popup-title");
  const popupX = document.getElementById("popup-x");
  const popupOk = document.getElementById("popup-ok");
  const audio = document.getElementById("sero-audio");

  const psDiscord = document.getElementById("ps-discord");
  const psTelegram = document.getElementById("ps-telegram");
  const psDoxbin = document.getElementById("ps-doxbin");
  const popupLink = document.getElementById("popup-link");
  const popupViews = document.getElementById("popup-views");

  function openPopup(name, role, pic, opts) {
    opts = opts || {};
    popupPic.src = pic;
    popupName.textContent = name;
    popupRole.textContent = role;
    popupTitle.textContent = name;
    // view counter
    const key = "view_" + name.toLowerCase().replace(/\s+/g, "_");
    let count = parseInt(localStorage.getItem(key), 10) || 0;
    count++;
    localStorage.setItem(key, String(count));
    popupViews.innerHTML = '<svg viewBox="0 0 24 24" width="12" height="12" style="vertical-align:-2px;margin-right:3px;"><path fill="#666" d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/></svg> ' + count;
    // socials are per-person; hide the ones this member doesn't have
    psDiscord.style.display  = opts.discord  ? "" : "none";
    psTelegram.style.display = opts.telegram ? "" : "none";
    psDoxbin.style.display   = opts.doxbin   ? "" : "none";
    if (opts.discord)  psDiscord.href  = opts.discord;
    if (opts.telegram) psTelegram.href = opts.telegram;
    if (opts.doxbin)   psDoxbin.href   = opts.doxbin;
    popupLink.style.display = opts.link ? "" : "none";
    if (opts.link) popupLink.href = opts.link;
    popup.classList.add("open");
    focusWindow(popup);
    registerTask(popup, name);
    // per-person sound
    if (opts.audio) {
      if (audio.getAttribute("src") !== opts.audio) audio.setAttribute("src", opts.audio);
      audio.currentTime = 0;
      audio.play().catch(() => {});
    } else {
      audio.pause();
    }
  }

  function closePopup() {
    popup.classList.remove("open");
    unregisterTask(popup);
    audio.pause();
  }

  document.querySelectorAll(".tb-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      openPopup(btn.dataset.name, btn.dataset.role, btn.dataset.pic, {
        discord:  btn.dataset.discord,
        telegram: btn.dataset.telegram,
        doxbin:   btn.dataset.doxbin,
        link:     btn.dataset.link,
        audio:    !!btn.dataset.audio,
      });
    });
  });

  document.getElementById("sero-icon").addEventListener("click", () => {
    openPopup("Sero", "Localsint Owner", "sero/sero.png", {
      discord: "https://discord.com/users/1505870670633111624",
      telegram: "https://t.me/xysghasdghjdfxcvzyx",
      link: "https://localsint.org",
      audio: "sero/sero.mp3",
    });
  });

  document.getElementById("yale-icon").addEventListener("click", () => {
    openPopup("Yale", "Dev / Co Founder", "yale/yale.png", {
      discord: "https://discord.com/users/1407152287209750558",
      telegram: "https://t.me/amidated",
      link: "https://localsint.org",
      audio: "yale/yale.mp3",
    });
  });

  document.getElementById("tophet-icon").addEventListener("click", () => {
    openPopup("Tophet", "Support", "tophet/tophet.png", {
      telegram: "https://t.me/t_phet",
      doxbin: "https://doxbin.com/users?query=tophet",
      audio: "tophet/tophet.mp3",
    });
  });

  document.getElementById("alex-icon").addEventListener("click", () => {
    openPopup("Alex Moar", "Localsint Owner", "alex%20moar/alex%20moar.png", {
      link: "https://localsint.org",
    });
  });

  popupX.addEventListener("click", closePopup);
  popupOk.addEventListener("click", closePopup);

  /* ---- start menu ---- */
  const startBtn = document.getElementById("start-btn");
  const startMenu = document.getElementById("startmenu");

  function toggleStart(force) {
    const willOpen = force !== undefined ? force : !startMenu.classList.contains("open");
    startMenu.classList.toggle("open", willOpen);
    startBtn.classList.toggle("open", willOpen);
  }

  startBtn.addEventListener("click", (e) => {
    e.stopPropagation();
    toggleStart();
  });

  startMenu.querySelectorAll(".sm-item[data-start]").forEach(item => {
    item.addEventListener("click", () => {
      const key = item.dataset.start;
      if (key === "sero") {
        openPopup("Sero", "Localsint Owner", "sero/sero.png", {
          link: "https://localsint.org",
          audio: "sero/sero.mp3",
        });
      } else if (key === "tophet") {
        openPopup("Tophet", "Support", "tophet/tophet.png", {
          telegram: "https://t.me/t_phet",
          doxbin: "https://doxbin.com/users?query=tophet",
          audio: "tophet/tophet.mp3",
        });
      } else {
        openApp(key);
      }
      toggleStart(false);
    });
  });

  const startLink = startMenu.querySelector("a.sm-item");
  if (startLink) startLink.addEventListener("click", () => toggleStart(false));

  // close on any outside click
  document.addEventListener("click", (e) => {
    if (!startMenu.contains(e.target) && e.target !== startBtn && !startBtn.contains(e.target)) {
      toggleStart(false);
    }
  });

  /* ---- app windows (localsint / projects / archive) ----
     EDIT THE CONTENT FOR EACH BELOW. Items with `url` open a link;
     items without one just sit there as list entries. */
  const APPS = {
    localsint: {
      title: "localsint",
      intro: "Open-source intelligence, done locally.",
      items: [
        { label: "localsint.org",  url: "https://localsint.org", link: true, meta: "OSINT tool", desc: "The main site — launch the toolkit." },
        { label: "Discord",        url: "https://discord.com/users/1505870670633111624", link: true, meta: "community", desc: "Join the team and get support." },
        { label: "Telegram",       url: "https://t.me/xysghasdghjdfxcvzyx", link: true, meta: "channel", desc: "Announcements and updates." }
      ]
    },
    projects: {
      title: "projects",
      intro: "Localsint projects:",
      items: [
        { label: "localsint.org", url: "https://localsint.org", link: true, meta: "OSINT tool", desc: "Open-source intelligence, done locally." }
      ]
    },
    archive: {
      title: "archive",
      intro: "Archived files:",
      items: []
    }
  };

  const appwin = document.getElementById("appwin");
  const appwinBar = document.getElementById("appwin-bar");
  const appwinTitle = document.getElementById("appwin-title");
  const appwinBody = document.getElementById("appwin-body");
  const appwinX = document.getElementById("appwin-x");

  function openApp(key) {
    const app = APPS[key];
    if (!app) return;
    appwinTitle.textContent = app.title;

    let html = "";
    if (app.intro) html += `<div class="aw-intro">${app.intro}</div>`;
    if (app.items && app.items.length) {
      html += `<div class="aw-list">`;
      for (const it of app.items) {
        const cls = "aw-item" + (it.link ? " link" : "");
        const inner =
          `<span class="aw-label">${it.label}</span>` +
          (it.meta ? `<span class="aw-meta">${it.meta}</span>` : "") +
          (it.desc ? `<span class="aw-desc">${it.desc}</span>` : "");
        if (it.url) {
          html += `<a class="${cls}" href="${it.url}" target="_blank" rel="noopener">${inner}</a>`;
        } else {
          html += `<div class="${cls}">${inner}</div>`;
        }
      }
      html += `</div>`;
    } else {
      html += `<div class="aw-empty">— empty —</div>`;
    }
    appwinBody.innerHTML = html;

    // cascade so it doesn't cover the icons
    appwin.style.left = "230px";
    appwin.style.top = "70px";
    appwin.classList.add("open");
    focusWindow(appwin);
    registerTask(appwin, app.title);
  }

  document.querySelectorAll(".icon[data-app]").forEach(icon => {
    icon.addEventListener("click", () => {
      openApp(icon.dataset.app);
    });
  });
  appwinX.addEventListener("click", () => {
    appwin.classList.remove("open");
    unregisterTask(appwin);
  });

  /* ---- window focus: bring the clicked window to the front ---- */
  let zTop = 30;
  function focusWindow(el) { el.style.zIndex = ++zTop; }
  [popup, appwin].forEach(win => {
    win.addEventListener("mousedown", () => { focusWindow(win); setActiveButton(win); });
  });

  /* ---- taskbar buttons for open windows ---- */
  const taskButtons = document.getElementById("task-buttons");
  const winButtons = new Map();   // window element -> its taskbar button

  function taskIcon(win) {
    if (win === popup) {
      return `<img src="${popupPic.src}" alt="" style="width:14px;height:14px;object-fit:cover;border-radius:2px;">`;
    }
    return `<svg viewBox="0 0 24 24" width="12" height="12"><rect x="3" y="4" width="18" height="16" rx="1" fill="none" stroke="#333" stroke-width="2"/><line x1="3" y1="8" x2="21" y2="8" stroke="#333" stroke-width="2"/></svg>`;
  }

  function setActiveButton(activeWin) {
    winButtons.forEach((btn, win) => {
      btn.classList.toggle("active", win === activeWin && win.classList.contains("open"));
    });
  }

  function registerTask(win, title) {
    let btn = winButtons.get(win);
    if (!btn) {
      btn = document.createElement("button");
      btn.className = "task-btn";
      btn.addEventListener("click", () => {
        if (win.classList.contains("open")) {
          win.classList.remove("open");           // minimize
          btn.classList.remove("active");
        } else {
          win.classList.add("open");              // restore
          focusWindow(win);
          setActiveButton(win);
        }
      });
      winButtons.set(win, btn);
      taskButtons.appendChild(btn);
    }
    btn.innerHTML = `<span class="tbi">${taskIcon(win)}</span><span class="tbl">${title}</span>`;
    setActiveButton(win);
  }

  function unregisterTask(win) {
    const btn = winButtons.get(win);
    if (btn) { btn.remove(); winButtons.delete(win); }
  }

  /* draggable app window */
  let aDrag = false, aOffX = 0, aOffY = 0;
  appwinBar.addEventListener("mousedown", (e) => {
    if (e.target === appwinX) return;
    aDrag = true;
    aOffX = e.clientX - appwin.offsetLeft;
    aOffY = e.clientY - appwin.offsetTop;
    e.preventDefault();
  });
  window.addEventListener("mousemove", (e) => {
    if (!aDrag) return;
    appwin.style.left = (e.clientX - aOffX) + "px";
    appwin.style.top  = (e.clientY - aOffY) + "px";
  });
  window.addEventListener("mouseup", () => { aDrag = false; });

  /* ---- draggable popup ---- */
  let dragging = false, offX = 0, offY = 0;
  popupBar.addEventListener("mousedown", (e) => {
    if (e.target === popupX) return;
    dragging = true;
    offX = e.clientX - popup.offsetLeft;
    offY = e.clientY - popup.offsetTop;
    e.preventDefault();
  });
  window.addEventListener("mousemove", (e) => {
    if (!dragging) return;
    popup.style.left = (e.clientX - offX) + "px";
    popup.style.top  = (e.clientY - offY) + "px";
  });
  window.addEventListener("mouseup", () => { dragging = false; });

  /* ---- taskbar clock ---- */
  function updateClock() {
    const now = new Date();
    document.getElementById("clock").textContent =
      String(now.getHours()).padStart(2, "0") + ":" +
      String(now.getMinutes()).padStart(2, "0");
  }
  updateClock();
  setInterval(updateClock, 10000);

  /* ---- volume control (0–100 + mute) ---- */
  const volWrap   = document.getElementById("vol");
  const volBtn    = document.getElementById("vol-btn");
  const volSlider = document.getElementById("vol-slider");
  const volVal    = document.getElementById("vol-val");

  let volume = 70, muted = false;
  try {
    const sv = localStorage.getItem("sero-vol");
    const sm = localStorage.getItem("sero-muted");
    if (sv !== null) volume = Math.max(0, Math.min(100, parseInt(sv, 10) || 0));
    if (sm !== null) muted = sm === "1";
  } catch (e) {}

  function applyVolume() {
    const effective = muted ? 0 : volume;
    audio.volume = effective / 100;
    audio.muted  = muted || volume === 0;
    volSlider.value = volume;
    volSlider.style.setProperty("--fill", effective + "%");
    volVal.textContent = volume;
    volWrap.classList.toggle("muted", muted || volume === 0);
    volWrap.classList.toggle("low", !muted && volume > 0 && volume <= 40);
    try {
      localStorage.setItem("sero-vol", String(volume));
      localStorage.setItem("sero-muted", muted ? "1" : "0");
    } catch (e) {}
  }

  volSlider.addEventListener("input", () => {
    volume = parseInt(volSlider.value, 10);
    if (volume > 0) muted = false;        // dragging up un-mutes
    applyVolume();
  });

  // click the speaker toggles mute (discord-style); slider shows on hover
  volBtn.addEventListener("click", () => {
    muted = !muted;
    applyVolume();
  });

  applyVolume();

  /* ---- pixelate the top-left avatar + the taskbar avatar ---- */
  function pixelateAvatar(img, blocks) {
    if (!img || img.dataset.pixelated) return;
    const run = () => {
      const nw = img.naturalWidth, nh = img.naturalHeight;
      if (!nw || !nh) return;
      const dw = img.clientWidth || nw, dh = img.clientHeight || nh;
      const bw = Math.max(2, blocks);
      const bh = Math.max(2, Math.round(blocks * dh / dw));
      try {
        // downscale (smoothed) to a tiny canvas...
        const small = document.createElement("canvas");
        small.width = bw; small.height = bh;
        small.getContext("2d").drawImage(img, 0, 0, bw, bh);
        // ...then blow it back up with NO smoothing = chunky pixels
        const big = document.createElement("canvas");
        big.width = dw; big.height = dh;
        const bc = big.getContext("2d");
        bc.imageSmoothingEnabled = false;
        bc.drawImage(small, 0, 0, dw, dh);
        img.dataset.pixelated = "1";
        img.src = big.toDataURL();
        img.style.imageRendering = "pixelated";
      } catch (e) {
        // canvas blocked (e.g. opened via file://) — leave image as-is
        img.style.imageRendering = "pixelated";
      }
    };
    if (img.complete && img.naturalWidth) run();
    else img.addEventListener("load", run, { once: true });
  }

  pixelateAvatar(document.querySelector("#sero-icon .pic"), 14);
  pixelateAvatar(document.querySelector("#yale-icon .pic"), 14);
  pixelateAvatar(document.querySelector("#tophet-icon .pic"), 14);
  pixelateAvatar(document.querySelector("#alex-icon .pic"), 14);
  document.querySelectorAll(".tb-btn img").forEach(img => pixelateAvatar(img, 12));

  /* ---- snow trail ---- */
  const trailCanvas = document.getElementById("trail");
  const tCtx = trailCanvas.getContext("2d");
  let flakes = [];
  let lastX = 0, lastY = 0;
  let trailActive = false;

  function resizeTrail() {
    trailCanvas.width = window.innerWidth;
    trailCanvas.height = window.innerHeight;
  }
  resizeTrail();
  window.addEventListener("resize", resizeTrail);

  const desktopSection = document.getElementById("desktop");
  function isDesktopVisible() {
    return desktopSection.classList.contains("show");
  }

  // soft shadow droplet — pops at the cursor and fades out
  function spawnFlakes(x, y) {
    flakes.push({ x: x, y: y, r: 4 + Math.random() * 3.5, life: 1 });
  }

  document.addEventListener("mousemove", (e) => {
    if (!isDesktopVisible()) return;
    if (!trailActive) { trailActive = true; lastX = e.clientX; lastY = e.clientY; return; }
    const dx = e.clientX - lastX;
    const dy = e.clientY - lastY;
    const dist = Math.sqrt(dx * dx + dy * dy);
    if (dist > 2) {
      spawnFlakes(e.clientX, e.clientY);
      lastX = e.clientX;
      lastY = e.clientY;
    }
  });

  const MAX_FLAKES = 320;

  function drawTrail() {
    tCtx.clearRect(0, 0, trailCanvas.width, trailCanvas.height);
    if (flakes.length > MAX_FLAKES) flakes.splice(0, flakes.length - MAX_FLAKES);
    for (let i = flakes.length - 1; i >= 0; i--) {
      const f = flakes[i];
      f.life -= 0.03;           // lingers much longer -> a long trail
      f.r += 0.4;               // little ripple outward
      if (f.life <= 0) { flakes.splice(i, 1); continue; }
      const grad = tCtx.createRadialGradient(f.x, f.y, 0, f.x, f.y, f.r);
      grad.addColorStop(0, `rgba(135,170,215,${f.life * 0.34})`);
      grad.addColorStop(1, `rgba(60,80,110,0)`);
      tCtx.beginPath();
      tCtx.arc(f.x, f.y, f.r, 0, Math.PI * 2);
      tCtx.fillStyle = grad;
      tCtx.fill();
    }
    requestAnimationFrame(drawTrail);
  }
  drawTrail();

  /* ---- dust particles ---- */
  const dustCanvas = document.getElementById("dust");
  const dCtx = dustCanvas.getContext("2d");
  let dustParticles = [];

  function resizeDust() {
    dustCanvas.width = window.innerWidth;
    dustCanvas.height = window.innerHeight;
  }
  resizeDust();
  window.addEventListener("resize", resizeDust);

  const DUST_COUNT = 40;
  for (let i = 0; i < DUST_COUNT; i++) {
    dustParticles.push({
      x: Math.random() * window.innerWidth,
      y: Math.random() * window.innerHeight,
      r: 0.3 + Math.random() * 1.5,
      vx: (Math.random() - 0.5) * 0.15,
      vy: (Math.random() - 0.5) * 0.1 - 0.05,
      life: 0.5 + Math.random() * 0.5,
      phase: Math.random() * Math.PI * 2,
    });
  }

  function drawDust() {
    dCtx.clearRect(0, 0, dustCanvas.width, dustCanvas.height);
    for (const d of dustParticles) {
      d.x += d.vx + Math.sin(d.phase + Date.now() * 0.0003) * 0.05;
      d.y += d.vy;
      if (d.x < 0) d.x = dustCanvas.width;
      if (d.x > dustCanvas.width) d.x = 0;
      if (d.y < 0) d.y = dustCanvas.height;
      if (d.y > dustCanvas.height) d.y = 0;
      const alpha = d.life * (0.3 + Math.sin(d.phase + Date.now() * 0.001) * 0.15);
      dCtx.beginPath();
      dCtx.arc(d.x, d.y, d.r, 0, Math.PI * 2);
      dCtx.fillStyle = `rgba(180,200,230,${alpha})`;
      dCtx.fill();
    }
    requestAnimationFrame(drawDust);
  }
  drawDust();

  /* ---- starfield ---- */
  const starCanvas = document.getElementById("stars");
  const sCtx = starCanvas.getContext("2d");
  let stars = [];

  function resizeStars() {
    starCanvas.width = window.innerWidth;
    starCanvas.height = window.innerHeight;
  }
  resizeStars();
  window.addEventListener("resize", resizeStars);

  const STAR_COUNT = 200;
  for (let i = 0; i < STAR_COUNT; i++) {
    stars.push({
      x: Math.random() * window.innerWidth,
      y: Math.random() * window.innerHeight,
      r: 0.2 + Math.random() * 1.8,
      alpha: 0.15 + Math.random() * 0.6,
      speed: 0.01 + Math.random() * 0.05,
      phase: Math.random() * Math.PI * 2,
      driftX: (Math.random() - 0.5) * 0.04,
      driftY: (Math.random() - 0.5) * 0.04,
    });
  }

  function drawStars() {
    sCtx.clearRect(0, 0, starCanvas.width, starCanvas.height);
    const t = Date.now() * 0.001;
    for (const s of stars) {
      const twinkle = s.alpha * (0.6 + 0.4 * Math.sin(t * s.speed * 10 + s.phase));
      s.x += s.driftX + Math.sin(t * 0.1 + s.phase) * 0.02;
      s.y += s.driftY + Math.cos(t * 0.08 + s.phase * 2) * 0.02;
      if (s.x < 0) s.x = starCanvas.width;
      if (s.x > starCanvas.width) s.x = 0;
      if (s.y < 0) s.y = starCanvas.height;
      if (s.y > starCanvas.height) s.y = 0;
      sCtx.beginPath();
      sCtx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
      sCtx.fillStyle = `rgba(180,200,240,${twinkle})`;
      sCtx.fill();
    }
    requestAnimationFrame(drawStars);
  }
  drawStars();
</script>
</body>
</html>
